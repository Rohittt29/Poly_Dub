# Whisper Configuration
WHISPER_MODEL=base
WHISPER_DEVICE=auto

# Output Configuration
OUTPUT_DIR=outputs
TEMP_DIR=temp
LOG_DIR=logs

# TTS Configuration
# Default Edge-TTS voice
TTS_VOICE=en-US-AriaNeural

# Quality Configuration
VIDEO_QUALITY=bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best
AUDIO_BITRATE=192k
